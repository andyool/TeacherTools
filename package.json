{
  "name": "teachertools-overlay",
  "version": "0.1.13",
  "private": true,
  "description": "An always-on-top desktop overlay with small utility tools for teachers.",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "node ./scripts/run-dev.mjs",
    "dev:server": "node ./scripts/run-dev.mjs --server",
    "dev:main": "tsc -p tsconfig.node.json --watch --preserveWatchOutput",
    "dev:renderer": "vite build --watch --clearScreen false",
    "dev:renderer:server": "vite --clearScreen false",
    "dev:electron": "node ./scripts/dev-electron.mjs",
    "dev:electron:server": "cross-env ELECTRON_RENDERER_MODE=server node ./scripts/dev-electron.mjs",
    "start": "cross-env ELECTRON_RUN_AS_NODE= electron .",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "tsc -p tsconfig.json && vite build",
    "build:main": "tsc -p tsconfig.node.json",
    "preview": "vite preview",
    "release:auto:patch": "node ./scripts/release-auto.mjs patch",
    "release:auto:minor": "node ./scripts/release-auto.mjs minor",
    "release:auto:major": "node ./scripts/release-auto.mjs major",
    "release:patch": "npm version patch && git push origin HEAD --follow-tags",
    "release:minor": "npm version minor && git push origin HEAD --follow-tags",
    "release:major": "npm version major && git push origin HEAD --follow-tags",
    "dist": "npm run build && electron-builder --publish never",
    "dist:mac": "npm run build && electron-builder --mac --publish never",
    "dist:mac:self-signed": "npm run build && cross-env TEACHERTOOLS_MAC_SELF_SIGN_REQUIRED=true electron-builder --mac --publish never",
    "dist:release": "npm run build && electron-builder --mac --win --publish never",
    "dist:win": "npm run build && electron-builder --win --x64 --publish never",
    "dist:win:dir": "npm run build && electron-builder --win dir --x64 --publish never",
    "dist:win:portable": "npm run build && electron-builder --win portable --x64 --publish never",
    "dist:win:installer": "npm run build && electron-builder --win nsis --x64 --publish never",
    "mac:self-signed:create": "node ./scripts/create-mac-self-signed-cert.mjs",
    "verify:mac-signature": "node ./scripts/verify-mac-update-signature.mjs"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.8.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.teachertools.overlay",
    "productName": "TeacherTools Overlay",
    "afterPack": "./scripts/sign-mac-adhoc.mjs",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "release"
    },
    "electronUpdaterCompatibility": ">=2.16",
    "publish": [
      {
        "provider": "github",
        "owner": "andyool",
        "repo": "TeacherTools"
      }
    ],
    "mac": {
      "artifactName": "TeacherTools-mac-${arch}.${ext}",
      "category": "public.app-category.education",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "artifactName": "TeacherTools-windows-setup.${ext}"
    },
    "portable": {
      "artifactName": "TeacherTools-windows-portable.${ext}"
    }
  }
}
