{
  "name": "teachertools-overlay",
  "version": "0.1.0",
  "private": true,
  "description": "An always-on-top desktop overlay with small utility tools for teachers.",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "node ./scripts/run-dev.mjs",
    "dev:server": "node ./scripts/run-dev.mjs --server",
    "dev:main": "tsc -p tsconfig.node.json --watch --preserveWatchOutput",
    "dev:renderer": "vite build --watch --clearScreen false",
    "dev:renderer:server": "vite --clearScreen false",
    "dev:electron": "node ./scripts/dev-electron.mjs",
    "dev:electron:server": "cross-env ELECTRON_RENDERER_MODE=server node ./scripts/dev-electron.mjs",
    "start": "cross-env ELECTRON_RUN_AS_NODE= electron .",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "tsc -p tsconfig.json && vite build",
    "build:main": "tsc -p tsconfig.node.json",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win --x64",
    "dist:win:dir": "npm run build && electron-builder --win dir --x64",
    "dist:win:portable": "npm run build && electron-builder --win portable --x64",
    "dist:win:installer": "npm run build && electron-builder --win nsis --x64"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.8.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.teachertools.overlay",
    "productName": "TeacherTools Overlay",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "mac": {
      "category": "public.app-category.education",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    }
  }
}
